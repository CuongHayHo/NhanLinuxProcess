flowchart TD
    U["User (cron create)"]
    CLI["CLI/TUI<br/>shell_mgr_cron_execute"]
    CTRL["C Controller<br/>access() kiểm tra quyền chạy script"]
    MGR["Manager<br/>fork() /bin/sh chạy pipeline cập nhật crontab"]
